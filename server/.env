SECRET_KEY=calogram-super-secret-key-2024
JWT_SECRET=calogram-jwt-secret-2024

# ── Database ──────────────────────────────────────────────────────
# DB_TYPE options:
#   sqlite  — no extra config needed, file is created automatically
#   mysql   — requires all MYSQL_* vars below
DB_TYPE=sqlite

# SQLite: path to .db file (relative to server/ folder)
DATABASE_PATH=calogram.db

# MySQL config (used only when DB_TYPE=mysql)
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=calogram_user
# MYSQL_PASSWORD=your_strong_password
# MYSQL_DATABASE=calogram_db
# MYSQL_CHARSET=utf8mb4

# ── Server ────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_PORT=28016
FRONTEND_PORT=28015

CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5501,http://127.0.0.1:5501

# ── Subscription pricing (USD) ───────────────────────────────────
# Prices shown on the landing / paywall pages
SUBSCRIPTION_MONTHLY_USD=4.99
SUBSCRIPTION_YEARLY_USD=29.99
SUBSCRIPTION_TRIAL_DAYS=7
